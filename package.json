{
  "name": "skill-porter",
  "version": "0.1.0",
  "description": "Convert agent skills between OpenClaw, Claude Code, and Cursor formats",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "skill-porter": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "tsx --test test/**/*.test.ts",
    "prepack": "npm run build"
  },
  "keywords": [
    "agent",
    "skills",
    "openclaw",
    "claude",
    "cursor",
    "cli"
  ],
  "author": "Rajan Rengasamy",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
